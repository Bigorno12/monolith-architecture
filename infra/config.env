# Database Routing
WELLDEV_URL=jdbc:mysql://mysql:3306/welldev

# Keycloak Routing
WELLDEV.KEYCLOAK.SERVER.URL=http://keycloak:7080
WELLDEV.KEYCLOAK.ISSUER-URI=http://keycloak:7080/realms/welldev
WELLDEV.RESOURCESERVER.JWT.SET.URI=http://keycloak:7080/realms/welldev/protocol/openid-connect/certs
WELLDEV.RESOURCESERVER.JWT.ISSUER.URI=http://keycloak:7080/realms/welldev
KC_HTTP_RELATIVE_PATH=/auth

# Spring Boot Configuration
SPRING_PROFILES_ACTIVE=k8s

